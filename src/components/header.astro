---
import { getGlobalData, getMediaURL } from "../lib/strapi";

const globalData = await getGlobalData();

const header = globalData.header_item;

---
<header>
 <div class="container">
 <nav class="navbar navbar-expand-lg">
  <!-- LOGO -->

{
    header?.logo?.url ? (
      <a class="navbar-brand" href="/">
        <img
          src={getMediaURL(header.logo.url)}
          alt={header.logo_text}
        />
      </a>
    ) : (
      <a class="navbar-brand logo-text" href="/">
        {header?.logo_text}
      </a>
    )
  }

  <!-- MENU -->
  <ul class="navbar-nav">
      {header?.menu?.map((item) => (
      <li class="nav-item">
        <a class="nav-link" href={item.link}>
          {item.title}
        </a>
      </li>
    ))}
  </ul>
  <div class="flex items-center gap-stack-md">
<button class="p-2 hover:opacity-70 transition-opacity duration-500">
<span class="material-symbols-outlined" data-icon="shopping_bag">shopping_bag</span>
</button>
<button class="p-2 hover:opacity-70 transition-opacity duration-500">
<span class="material-symbols-outlined" data-icon="person">person</span>
</button>
</div>

  <!-- CTA -->
  </nav>
  </div>
</header>
<style>
header {
    padding-top: 16px;
    padding-bottom: 16px;
    transition: all 0.5s ease 0s;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 999;
    border:1px solid rgb(196 199 199 / 0.3);
    background-color: rgb(255 255 255 / 0.9);
    backdrop-filter: blur(12px);
}
.navbar  {
    justify-content: space-between;

}
.navbar-brand img {
    transition-duration: 0.5s;
    width: 222px;
}
.logo-text {
  font-size: 32px;
  line-height: 40px;
  font-weight: 400;
  font-family: EB Garamond, serif;
}
.navbar-nav>li.has-sub {
    padding-right: 13px;
}
.navbar-nav>li {
    margin-left: 10px;
    float: left;
}
.navbar-nav>li>a {
font-size: 16px;
    line-height: 24px;
    font-weight: 400;
    color: #000;
        text-transform: uppercase;
    font-family: Hanken Grotesk, sans-serif;
}
button {
      border: 0;
    background: transparent;
}
button span {
      font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
          font-size: 20px;
}
</style>