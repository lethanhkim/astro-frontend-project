---
const {
  heading_title,
  newsletter,
} = Astro.props;
---

<section class="subscribe">
  <div class="container">

    <div class="heading">
      {heading_title?.title && (
        <h2>{heading_title.title}</h2>
      )}

      {heading_title?.description && (
        <p>{heading_title.description}</p>
      )}
    </div>

    <form class="subscribe-form">

      <input
        type="email"
        placeholder={newsletter?.placeholder}
        aria-label={newsletter?.title}
      />

      <button type="submit">
        {newsletter?.button_text}
      </button>

    </form>

  </div>
</section>
<style>
    .subscribe {
        border: 1px solid rgb(217 197 178 / 0.2);;
    }
    .heading {
        text-align: center;
    }
    .heading h2 {
    font-size: 48px;
    line-height: 56px;
    font-weight: 400;
    }
    .subscribe-form {
        margin-top: 50px;
        text-align: center;
    }
    .subscribe-form button {
            font-size: 12px;
    line-height: 16px;
    letter-spacing: 0.1em;
    font-weight: 600;
    background: #000;
    color: #fff;
    text-transform: uppercase;
    height: 50px;
    border: 0;
    width: 150px;
    }
     .subscribe-form input {
            height: 50px;
    padding: 20px;
    border: 0;
    border-bottom: 1px solid;
    background: transparent;
     }
</style>