---

import { getPortfolios, getMediaURL } from "../../lib/strapi";

const portfolios = await getPortfolios();

const { title } = Astro.props;
---

<section class="portfolio-section">
      <div class="container">
            <h2 class="heading-text">
      {title}
    </h2>

<div class="row">
  <div class="col-lg-7">
    {
      portfolios[0] && (

        <article class="portfolio-item featured-post">

          <a class="thumnail" href={`/portfolio/${portfolios[0].slug}`}>

           <img
              src={getMediaURL(portfolios[0].image.url)}
              alt={portfolios[0].title}
            />
          </a>

          <a class="post-title-link" href={`/portfolio/${portfolios[0].slug}`}><h3 class="post-title">{portfolios[0].title}</h3></a>

          <p class="post-des">{portfolios[0].description}</p>

        </article>

      )
    }

  </div>

  <div class="col-lg-5">

    <div class="row">

      {
        portfolios.slice(1, 3).map((item) => (

          <div class="col-12">

            <article class="portfolio-item small-post">

              <a class="thumnail" href={`/portfolio/${item.slug}`}>

               <img
                  src={getMediaURL(item.image.url)}
                  alt={item.title}
                />

              </a>

              <a class="post-title-link" href={`/portfolio/${item.slug}`}> <h3 class="post-title">{item.title}</h3></a>

            </article>

          </div>

        ))
      }

    </div>

  </div>

</div>
</div>
</section>
<style>
  .portfolio-section {
    background-color: #f3f3f4;
  }
  .portfolio-item img {
      width: 100%;
     transition: .3s;

  }
  .thumnail {
        width: 100%;
    margin-bottom: 24px;
    overflow: hidden;
    display: inline-block;
  }
  .post-title {
        font-size: 32px;
    line-height: 40px;
    font-weight: 400;
  }
    .post-title-link {
      text-decoration: none;
    }
    h3 {
      transition: .3s;
    }
    .portfolio-item:hover h3 {
      color:#d9c5b2 ;
      transition: .3s;
    }
    .portfolio-item:hover img {
      scale: 1.1;
       transition: .3s;
    }
</style>