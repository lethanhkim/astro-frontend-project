---
import { getMediaURL } from "../../lib/strapi";

const {
  background_color,
  heading_title,
  button,
  surface_img,
} = Astro.props;
---

<section class={`surface-about section bg-${background_color || "light"}`}>
  <div class="container">

    <div class="row align-items-center">

      <div class="col-lg-6">
        <span class="sub-title">  {heading_title?.sub_title}</span>
            <h2 class="heading-title">
            {heading_title?.title}
            </h2>

            <p class="description">
            {heading_title?.description}
            </p>

        {
          button && (
            <a
              href={button.btn_link}
              class={`btn btn-${button.variant}`}
              target={button.target ? "_blank" : "_self"}
            >
              {button.btn_text}
              <span class="material-symbols-outlined text-sm" data-icon="east">east</span>
            </a>
          )
        }

      </div>

      <div class="col-lg-6">

        <div class="surface-images">

          {
            surface_img?.map((img) => (
              <div class="surface-image">
                <img
                  src={getMediaURL(img.url)}
                  alt={img.alternativeText || img.name}
                  loading="lazy"
                />
              </div>
            ))
          }

        </div>

      </div>

    </div>

  </div>
</section>

<style>
.surface-images {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.surface-image img {
  width: 100%;
  display: block;
}

.bg-grey {
  background-color: #f3f3f4;
}

.bg-light {
  background-color: #fff;
}
</style>