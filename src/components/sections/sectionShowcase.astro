---
import { getMediaURL } from "../../lib/strapi";

const {
  top_left_infor,
  center_title,
  center_image,
  bottom_left_image,
  top_right_image,
  bottom_right_text,
  background_color,
} = Astro.props;
---

<section class={`material-showcase section bg-${background_color || "grey"}`}>
  <div class="container">

    <div class="material-grid">

      <div class="material-info">
        <span class="material-number">
          {top_left_infor?.number}
        </span>

        <h3 class="material-title">
          {top_left_infor?.title}
        </h3>

        <p class="material-des">
          {top_left_infor?.description}
        </p>
      </div>

      <div class="material-main-image">
        <img
          src={getMediaURL(center_image?.url)}
          alt={center_title}
        />

        <h2 class="main-title">
          {center_title}
        </h2>
      </div>

      <div class="material-top-image">
        <img
          src={getMediaURL(top_right_image?.url)}
          alt=""
        />
      </div>

      <div class="material-bottom-image">
        <img
          src={getMediaURL(bottom_left_image?.url)}
          alt=""
        />
      </div>

      <div class="material-quote">
        <p>{bottom_right_text}</p>
      </div>

    </div>

  </div>
</section>
<style>
    .material-showcase {
    padding: 100px 0;
}

.bg-grey {
    background: #f3f3f4;
}

.material-grid {
    display: grid;
    grid-template-columns: 340px 1fr 340px;
    grid-template-rows: repeat(2, 1fr);
    gap: 24px;
}

.material-grid > div {
    overflow: hidden;
}

.material-info {
    background: #f8f7f6;
    padding: 48px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.material-number {
    display: block;
    margin-bottom: 12px;
    font-size: 20px;
    line-height: 1;
    font-weight: 500;
    color: #161616;
}

.material-title {
    margin: 0 0 16px;
    font-size: 24px;
    line-height: 1.2;
    font-family: "EB Garamond", serif;
}

.material-des {
    margin: 0;
    font-size: 18px;
    line-height: 1.7;
    font-style: italic;
    color: #555;
}

.material-main-image {
    grid-column: 2;
    grid-row: 1 / span 2;
    position: relative;
}

.material-main-image img,
.material-top-image img,
.material-bottom-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s ease;
}

.material-main-image:hover img,
.material-top-image:hover img,
.material-bottom-image:hover img {
    transform: scale(1.05);
}

.main-title {
    position: absolute;
    left: 40px;
    bottom: 40px;
    margin: 0;
    color: #fff;
    font-size: 56px;
    line-height: 1.1;
    font-family: "EB Garamond", serif;
    font-weight: 400;
}

.material-quote {
    background: #f8f7f6;
    padding: 48px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
}

.material-quote p {
    margin: 0;
    max-width: 240px;
    font-size: 24px;
    line-height: 1.6;
    color: #444;
}

.material-main-image img,
.material-top-image img,
.material-bottom-image img {
    display: block;
}

/* Tablet */
@media (max-width: 991px) {

    .material-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .material-main-image {
        grid-column: 1 / -1;
        grid-row: auto;
    }

    .main-title {
        font-size: 42px;
    }
}

/* Mobile */
@media (max-width: 767px) {

    .material-grid {
        grid-template-columns: 1fr;
    }

    .material-main-image {
        grid-column: auto;
    }

    .main-title {
        left: 24px;
        bottom: 24px;
        font-size: 32px;
    }

    .material-info,
    .material-quote {
        padding: 32px 24px;
    }
}
</style>